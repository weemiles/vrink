# Public market discovery settings
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com

# Scan only active, open markets and sort by volume_24hr
MARKET_LIMIT=75
MARKET_ORDER=volume_24hr
TAG_ID=

# Strategy filters
MIN_LIQUIDITY_USD=15000
MIN_VOLUME_USD=25000
MAX_SPREAD_CENTS=6
MIN_HOURS_TO_CLOSE=8
MIN_EDGE_BPS=400

# Paper trading bankroll controls
BANKROLL_USD=1000
MAX_POSITION_PCT=0.03
SCAN_INTERVAL_SECONDS=300

# File locations (relative paths are resolved from the project root)
MANUAL_SIGNALS_PATH=manual_signals.json
REPORTS_DIR=reports
RESEARCH_DIR=research

# Leave live trading disabled unless you explicitly wire in py-clob-client later.
CHAIN_ID=137
SIGNATURE_TYPE=0
ALLOW_LIVE_TRADING=false
PRIVATE_KEY=
FUNDER_ADDRESS=
POLY_API_KEY=
POLY_PASSPHRASE=
POLY_API_SECRET=
