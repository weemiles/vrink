# App environment
VITE_APP_ENV=dev

# Supabase (frontend runtime)
VITE_SUPABASE_PROJECT_ID=odjnidzoerrygtaivuru
VITE_SUPABASE_ANON_KEY=your_public_anon_key

# Edge Function security
# Comma-separated origins (supports wildcard like https://*.vercel.app)
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,https://*.vercel.app

# Signup rate-limit
SIGNUP_RATE_LIMIT_MAX=8
SIGNUP_RATE_LIMIT_WINDOW_MS=600000

# Optional: Cloudflare Turnstile (signup anti-bot)
# TURNSTILE_SECRET_KEY=your_turnstile_secret
